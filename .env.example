# Puerto (Railway lo asigna automáticamente, no cambiar)
PORT=3000

# Ruta de la base de datos SQLite
# En Railway, apuntar al volumen montado: /data/inventory.sqlite
# En local, dejar vacío para usar la carpeta del proyecto
DB_PATH=/data/inventory.sqlite

# Clave secreta para JWT (CAMBIAR por una cadena larga y única)
JWT_SECRET=COLOCA_AQUI_UNA_CLAVE_SECRETA_MUY_LARGA_Y_SEGURA
